# Site kök URL (PayTR yönlendirme adresleri için)
SITE_URL=https://onlinevipdershane.com

# PayTR — https://www.paytr.com/magaza/bilgi
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
# Test modu: 1 = test, 0 veya boş = canlı
PAYTR_TEST_MODE=0

# Stripe (opsiyonel — PayTR yoksa kullanılır)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Ders Online VIP Koçluk paneli (öğretmen listesi + özel ders talepleri)
KOCLUK_PANEL_URL=https://www.dersonlinevipkocluk.com
OZEL_DERS_WEBHOOK_SECRET=

# Panel → site öğretmen yayın sync (HMAC). Panel env ile AYNI secret olmalı.
# Panel: SITE_TEACHERS_WEBHOOK_URL=https://onlinevipdershane.com/api/teachers-sync
SITE_TEACHERS_WEBHOOK_SECRET=
